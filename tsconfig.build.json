{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Node",
        "outDir": "./dist",
        "declaration": true,
        "emitDeclarationOnly": false,
        "isolatedModules": false,
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "sourceMap": false
    },
    "include": ["src"],
    "exclude": ["node_modules", "playground", "dist"]
}
