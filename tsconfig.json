{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "allowSyntheticDefaultImports": true,
        "paths": {
            "asi-wallet-sdk": ["./dist"],

            "@services/": ["./src/services"],
            "@domains/": ["./src/domains"],
            "@config": ["./src/config"],
            "@utils": ["./src/utils"],

            "@services/*": ["./src/services/*"],
            "@domains/*": ["./src/domains/*"],
            "@config/*": ["./src/config/*"],
            "@utils/*": ["./src/utils/*"]
        }
    }
}
