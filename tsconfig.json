{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Node",
        "allowSyntheticDefaultImports": true,
        "baseUrl": ".",
        "paths": {
            "asi-wallet-sdk": ["dist"],
            "@/*": ["src/*"],

            "@services/": ["src/services/"],
            "@domains/": ["src/domains/"],
            "@config": ["src/config"],
            "@utils": ["src/utils"],

            "@services/*": ["src/services/*"],
            "@domains/*": ["src/domains/*"],
            "@config/*": ["src/config/*"],
            "@utils/*": ["src/utils/*"]
        }
    }
}
